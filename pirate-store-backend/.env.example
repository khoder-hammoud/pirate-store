# 🔧 Environment Variables Configuration
# =====================================
# انسخ هذا الملف إلى .env وعدّل القيم

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/pirate-store

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your-secret-key-here-change-this-in-production
JWT_EXPIRE=7d

# Refund Service Configuration
REFUND_RETRY_ATTEMPTS=3
REFUND_RETRY_DELAY=5000
REFUND_SUCCESS_RATE=0.7

# Email Configuration (اختياري)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@piratestore.com

# Frontend URL (للـ CORS)
FRONTEND_URL=http://localhost:3000

# Logging Configuration (اختياري)
LOG_LEVEL=debug
LOG_FILE=./logs/app.log
